# ============================================================
# CRUD Pedidos — .gitignore
# ============================================================

# ============================================================
# Entornos virtuales y dependencias
# ============================================================
venv/
.venv/
env/
.env
.env.local
.env.production
*.env

# ============================================================
# Byte-compiled / optimized
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyc

# ============================================================
# Distribución / empaquetado
# ============================================================
*.egg-info/
*.egg
*.whl
*.tar.gz
dist/
build/

# ============================================================
# IDE y editores
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ============================================================
# Jupyter Notebook
# ============================================================
.ipynb_checkpoints

# ============================================================
# Base de datos (archivos locales)
# ============================================================
db.sqlite3
*.sqlite3
*.db

# ============================================================
# Logs
# ============================================================
*.log
logs/

# ============================================================
# Archivos de sistema operativo
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Herramientas de testing y cobertura
# ============================================================
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ============================================================
# Docker
# ============================================================
docker-compose.override.yml
*.dockerfile

# ============================================================
# Secretos y credenciales
# ============================================================
# NUNCA subas estos archivos al repositorio
*.pem
*.key
*.crt
secrets/
credentials/

# ============================================================
# Archivos temporales
# ============================================================
*.tmp
*.temp
temp/
tmp/

# ============================================================
# Migraciones de Django (solo si quieres ignorarlas)
# ============================================================
# Descomenta si no quieres trackear migraciones
# **/migrations/*.py
# !**/migrations/__init__.py

# ============================================================
# Archivos de exportación generados
# ============================================================
exports/
*.pdf
*.xlsx
*.xls

# ============================================================
# Archivos de debug
# ============================================================
debug_*.py
test_*.py
*_test.py
